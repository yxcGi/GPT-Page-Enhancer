{
  "manifest_version": 3,
  "name": "GPT Page Enhancer",
  "description": "Enhance ChatGPT pages with adjustable content width, Markdown prompts, and click-to-copy LaTeX formulas.",
  "version": "1.2.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GPT Page Enhancer",
    "default_popup": "popup.html"
  }
}
