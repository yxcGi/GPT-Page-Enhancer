{
  "manifest_version": 3,
  "name": "GPT Page Enhancer",
  "description": "Enhance ChatGPT pages with adjustable content width, page backgrounds, Markdown prompts, and click-to-copy LaTeX formulas.",
  "version": "1.4.3",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["vendor/katex/katex.min.js", "mainWorld.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["vendor/katex/katex.min.css", "content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/katex/fonts/*"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "GPT Page Enhancer",
    "default_popup": "popup.html"
  }
}
